        <exclude-subsystems>
            <subsystem name="mail"/>
        </exclude-subsystems>
        <exclusions>
            <module name="javax.mail.api"/>
            <module name="com.sun.mail.javax.mail"/>
            <module name="javax.activation.api"/>
